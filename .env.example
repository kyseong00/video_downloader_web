# NextAuth session encryption key (REQUIRED) - generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-this-secret-in-production

# Service URL (change to your domain or host IP if not localhost)
NEXTAUTH_URL=http://localhost:3033
AUTH_URL=http://localhost:3033

# Host user/group ID for volume permissions (check with: id -u / id -g)
PUID=1000
PGID=1000
